# Dev stack environment template
# Copy to .env and adjust values as needed

# SQL Server
# For Apple Silicon/x64, we use azure-sql-edge by default in compose
# MSSQL_IMAGE=mcr.microsoft.com/azure-sql-edge:latest
MSSQL_SA_PASSWORD=AdminPassword!

# Redis
# Configure password
REDIS_PASSWORD=

# PostgreSQL
POSTGRES_IMAGE=postgres:17-alpine
POSTGRES_DB=rubys
POSTGRES_USER=postgres
POSTGRES_PASSWORD=AdminPassword!
POSTGRES_PORT=5432